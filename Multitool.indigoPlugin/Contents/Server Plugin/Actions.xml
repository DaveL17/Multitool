    <Action id="emailBatteryLevelReport" uiPath="Send Report">
        <Name>Battery Level Report</Name>
        <ConfigUI>
            <Field id="sendReportToLabel" type="label">
                <Label>Select the email device:</Label>
            </Field>
            <Field id="email_device" type="menu" tooltip="Select the Email+ device that will send the report.">
                <Label>Mail Device:</Label>
                <List class="indigo.devices" filter="com.indigodomo.email"/>
            </Field>
            <Field id="email_address" type="textfield" tooltip="Enter the recipient's email address.">
                <Label>Email Address:</Label>
            </Field>
            <Field id="emailAddressInstructions" type="label">
                <Label>Separate multiple emails with a comma. The email address field supports substitutions.</Label>
            </Field>
        </ConfigUI>
        <CallbackMethod>email_battery_level_report</CallbackMethod>
    </Action>

